# ─────────────────────────────────────────────
#  InvestPro — Environment Variables Template
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production
SITE_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com,https://your-app.onrender.com

# MongoDB (use Atlas for production)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/investpro?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_random_hex_chars
JWT_EXPIRES=30d

# Admin account (created via: npm run seed)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace_with_strong_password_in_hosting_dashboard

# Wallet limits (USD)
MIN_DEPOSIT=10
MAX_DEPOSIT=50000
MIN_WITHDRAW=10
MAX_WITHDRAW=10000
WITHDRAWAL_FEE=10

# Training plan
TRAINING_DAYS=5
TRAINING_DAILY=0.10

# Referral commissions (% of deposit amount)
REFERRAL_L1=15
REFERRAL_L2=10
REFERRAL_L3=5

# Cron schedule — hourly rewards
HOURLY_CRON=0 * * * *

# Platform deposit wallets
WALLET_USDT_TRC20=YOUR_TRC20_ADDRESS
WALLET_USDT_BEP20=YOUR_BEP20_ADDRESS
WALLET_USDT_POLYGON=YOUR_POLYGON_ADDRESS

# Optional: Telegram admin notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT=
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
TELEGRAM_SETUP_KEY=replace_with_private_setup_key
TELEGRAM_LOCAL_WEBHOOK_URL=http://localhost:5000/api/telegram/webhook

# Optional: AI support assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
